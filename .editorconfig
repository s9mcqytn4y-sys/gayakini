# EditorConfig for gayakini project
# Optimal for Android Studio / IntelliJ IDEA + ktlint

root = true

[*.{kt,kts}]
max_line_length = 120
insert_final_newline = true
indent_size = 4
continuation_indent_size = 4
trim_trailing_whitespace = true

# Standard ktlint rules
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_import-ordering = disabled
ktlint_standard_final-newline = enabled
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled

# IntelliJ specific formatting (avoids property-not-supported warnings while maintaining behavior)
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^
ij_kotlin_name_count_to_use_star_import = 999
ij_kotlin_name_count_to_use_star_import_for_members = 999

# Fix typo warning in IDE for word 'ktlint'
# spell-checker: ignore ktlint
