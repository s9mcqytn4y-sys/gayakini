{
  "mcpServers": {
    "gayakini-context": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "./tooling/mcp/start-context.ps1"
      ],
      "env": {
        "PROJECT_ROOT": "C:/Software/gayakini"
      }
    }
  },
  "resources": [
    {
      "uri": "mcp://gayakini/docs/openapi",
      "name": "Gayakini OpenAPI Specification",
      "description": "The authoritative API contract for the Gayakini E-commerce system.",
      "mimeType": "text/yaml",
      "localPath": "docs/brand-fashion-ecommerce-api-final.yaml"
    },
    {
      "uri": "mcp://gayakini/docs/schema",
      "name": "Gayakini Database Schema",
      "description": "The physical database schema and Flyway migration history.",
      "mimeType": "text/x-sql",
      "localPath": "src/main/resources/db/migration/V1__initial_schema.sql"
    }
  ]
}
