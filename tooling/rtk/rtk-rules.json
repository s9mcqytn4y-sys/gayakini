{
  "noisyPatterns": [
    "^\\s*$",
    "^\\s*(Done|Success|Finished) in \\d+(\\.\\d+)?(ms|s|m|h)\\s*$",
    "^\\s*[\\|\\-\\\\/]\\s*$",
    "Scanning for projects...",
    "Using cached results",
    "up-to-date",
    "skipped",
    "Download(ing|ed)",
    "Check(ing|ed)",
    "^\\.*$",
    "^\\s*at .+\\(Unknown Source\\)$",
    "^\\s*at .+\\(\\d+\\)$",
    "^\\s*at .+\\(Native Method\\)$",
    "Hibernate: ",
    "Resolved [a-zA-Z0-9.]+Exception",
    "Starting search for .+\\.sql",
    "Validated \\d+ migrations",
    "Current version of schema",
    "Schema .?commerce.? is up to date",
    "OpenJDK 64-Bit Server VM warning",
    "spring.profiles.active=test",
    "Starting .?GayakiniApplication.?",
    "The following 1 profile is active: .?test.?",
    "No active profile set, falling back to 1 default profile: .?default.?",
    "Started .?GayakiniApplication.? in \\d+\\.\\d+ seconds",
    "Adding .?X-Order-Token.? to header",
    "Menerima webhook Midtrans untuk Order: "
  ],
  "preservePatterns": [
    "ERROR:",
    "WARNING:",
    "Caused by:",
    "BUILD FAILED",
    "BUILD SUCCESSFUL",
    "Tests Summary:",
    "failedTests:",
    "\\.(kt|java|sql|yml|yaml|kts):\\d+:\\d+",
    "\\d+ passed, \\d+ failed",
    "Condition failed:",
    "EXPECTED:",
    "ACTUAL:",
    "DIFF:",
    "AssertionFailedError"
  ],
  "collapsePatterns": [
    "^\\s*at (org\\.gradle|org\\.springframework|java\\.base|kotlin|jdk\\.proxy|org\\.junit|org\\.apache|org\\.hibernate|com\\.sun|sun\\.reflect).+",
    "^\\s*at (com\\.gayakini).+"
  ],
  "progressPatterns": [
    "\r",
    "^\\s*\\d+%.+$",
    "^\\s*\\d+/\\d+ (kB|MB|GB).+$",
    "^\\s*<[-=]*> \\d+%"
  ],
  "envLeakPatterns": [
    "token",
    "secret",
    "password",
    "key",
    "Authorization"
  ],
  "maxRepeatedLines": 2,
  "maxStackFrames": 3,
  "maxSectionLines": 50,
  "truncateLongLineAt": 400,
  "profiles": {
    "conservative": {
      "stripAnsi": true,
      "dedupe": true,
      "collapseStack": false,
      "truncateOutput": false,
      "dropNoisy": true
    },
    "balanced": {
      "stripAnsi": true,
      "dedupe": true,
      "collapseStack": true,
      "truncateOutput": true,
      "dropNoisy": true
    },
    "aggressive": {
      "stripAnsi": true,
      "dedupe": true,
      "collapseStack": true,
      "truncateOutput": true,
      "dropNoisy": true,
      "summaryOnlyOnSuccess": true
    }
  }
}
