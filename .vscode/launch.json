      "name": "GayakiniApplication",
      "request": "launch",
      "mainClass": "com.gayakini.GayakiniApplicationKt",
      "projectName": "gayakini",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local",
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_NAME": "gayakini",
