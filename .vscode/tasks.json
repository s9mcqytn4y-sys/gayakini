{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gradle: check",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/c",
        ".\\gradlew.bat check --console=plain"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Workspace: JSON sanity",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "@('.vscode\\settings.json','.vscode\\launch.json','.vscode\\tasks.json','.vscode\\extensions.json') | ForEach-Object { if (Test-Path $_) { Get-Content $_ -Raw | ConvertFrom-Json | Out-Null } }"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
