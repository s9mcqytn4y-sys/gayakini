# --- APP CORE ---
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
JWT_SECRET=docker-compose-secret-key-at-least-32-characters
JWT_ISSUER=gayakini

# --- DATABASE (POSTGRESQL 16) ---
# For docker-compose: use 'db' as host. For local: use 'localhost'
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gayakini
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=commerce

# --- EMAIL (MAILPIT) ---
# SMTP_HOST=localhost (local) or 'mail' (docker-compose)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=null
SMTP_PASSWORD=null

# --- MIDTRANS SANDBOX ---
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_API_URL=https://api.sandbox.midtrans.com/v2
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v1/transactions

# --- BITESHIP SANDBOX ---
BITESHIP_API_KEY=biteship_test_xxxxxxxxxxxx
BITESHIP_API_URL=https://api.biteship.com/v1
BITESHIP_WEBHOOK_SECRET=replace-with-local-webhook-secret

# --- CORS & BASE URL ---
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
