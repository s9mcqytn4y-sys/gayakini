# --- APP CORE ---
SPRING_PROFILES_ACTIVE=local
APP_ENV=local
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gayakini
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=commerce

# --- SECURITY ---
# Min 32 chars for HS256
JWT_SECRET=super-secret-key-at-least-32-characters-long
JWT_ISSUER=gayakini
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- INFRASTRUCTURE ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# --- MIDTRANS (SANDBOX) ---
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_API_URL=https://api.sandbox.midtrans.com/v2
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v1/transactions

# --- BITESHIP (SANDBOX) ---
BITESHIP_API_KEY=biteship_test_xxxxxxxxxxxx
BITESHIP_API_URL=https://api.biteship.com/v1
BITESHIP_WEBHOOK_SECRET=replace-with-local-webhook-secret

# --- RUNTIME OPTIMIZATION ---
# Useful for Docker containers
JAVA_TOOL_OPTIONS="-XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0"
