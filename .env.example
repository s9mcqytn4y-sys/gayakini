# --- APP CORE ---
# Selection: local, dev, staging
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# --- DATABASE (PostgreSQL 17) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gayakini
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=commerce

# --- SECURITY ---
JWT_SECRET=super-secret-key-at-least-32-characters-long
JWT_ISSUER=gayakini
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- INFRASTRUCTURE ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# --- MIDTRANS (SANDBOX) ---
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_API_URL=https://api.sandbox.midtrans.com/v2
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v1/transactions

# --- BITESHIP (SANDBOX) ---
BITESHIP_API_KEY=biteship_test_xxxxxxxxxxxx
BITESHIP_API_URL=https://api.biteship.com/v1
BITESHIP_WEBHOOK_SECRET=replace-with-local-webhook-secret

# --- RUNTIME MEMORY (JAVA 17+) ---
# Percentage-based for container/limit awareness.
# Local (Host): Calculates against Physical RAM. Recommend: 25% Initial, 50% Max.
# Dev/Staging (Docker): Calculates against 'mem_limit' defined in compose.
# Options:
# -XX:+ExitOnOutOfMemoryError : Ensures container restarts on OOM instead of hanging.
JAVA_TOOL_OPTIONS="-XX:InitialRAMPercentage=25 -XX:MaxRAMPercentage=50 -XX:+ExitOnOutOfMemoryError"
